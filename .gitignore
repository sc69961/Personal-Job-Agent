# ── Secrets — NEVER commit these ──────────────────────────────────────────
config/google_credentials.json
config/google_token.pickle

# ── Runtime output (large, regenerated each run) ──────────────────────────
output/
!output/.gitkeep
# Persistent data — committed to repo so they survive Actions cache expiry
!output/first_seen_registry.json
!output/rejected_jobs.json
!output/market_stats.json

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
*.egg

# ── macOS ─────────────────────────────────────────────────────────────────
.DS_Store

# ── Firebase ──────────────────────────────────────────────────────────────
.firebase/
